{
  "name": "nodejs-middleware",
  "version": "1.0.0",
  "description": "Node.js middle layer service for microservice architecture",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --coverage --forceExit --testPathIgnorePatterns=integration",
    "test:integration": "jest --forceExit --testPathPattern=integration --testTimeout=120000"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "pg": "^8.19.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.12.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4",
    "testcontainers": "^11.12.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js"
    ]
  }
}
